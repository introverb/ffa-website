# Copy this file to `.env.local` for local dev, and set the same vars on
# your host (Railway / Cloudflare Pages) for production.

# Resend — used by /api/possibilia-submission to email submissions to you.
# 1. Sign up at https://resend.com
# 2. Settings → API Keys → Create API Key (full access for this project)
# 3. Paste the key here.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx

# The "from" address on submission emails. MUST be on a domain you've
# verified inside Resend (Settings → Domains → Add domain → DNS records).
# For testing without a verified domain, use:
#   Possibilia Submissions <onboarding@resend.dev>
POSSIBILIA_FROM_EMAIL=Possibilia Submissions <submissions@futureaesthetics.foundation>

# Where submissions get sent. Can be your personal email or a shared inbox.
POSSIBILIA_TO_EMAIL=ollipayne182@gmail.com

# --- OURS storefront (/ours/collect) -----------------------------------
# Stripe test-mode secret key. Dashboard → Developers → API keys ("Secret
# key" — starts with "sk_test_" in test mode). Switch to a live key
# (starts "sk_live_") only once the full flow is verified end-to-end.
STRIPE_SECRET_KEY=

# Signing secret for the storefront's webhook. In the Stripe Dashboard:
# Developers → Webhooks → Add endpoint → URL = https://<your-domain>/api/
# storefront-webhook → events: checkout.session.completed and
# checkout.session.expired. Stripe shows the signing secret (starts
# "whsec_") once the endpoint is created — paste it here.
STRIPE_WEBHOOK_SECRET=

# Upstash Redis — stores live sold/reserved state (updated by the
# webhook, read on every page load). Free tier is plenty for this.
# 1. Sign up at https://upstash.com, create a Redis database (any region).
# 2. Database page → REST API section → copy both values below.
# Without these two set, the checkout route refuses to start a
# purchase (fails safe) rather than accept an unrecorded sale.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
