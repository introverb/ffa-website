# Copy this file to `.env.local` for local dev, and set the same vars on
# your host (Railway / Cloudflare Pages) for production.

# Resend — used by /api/possibilia-submission to email submissions to you.
# 1. Sign up at https://resend.com
# 2. Settings → API Keys → Create API Key (full access for this project)
# 3. Paste the key here.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx

# The "from" address on submission emails. MUST be on a domain you've
# verified inside Resend (Settings → Domains → Add domain → DNS records).
# For testing without a verified domain, use:
#   Possibilia Submissions <onboarding@resend.dev>
POSSIBILIA_FROM_EMAIL=Possibilia Submissions <submissions@futureaesthetics.foundation>

# Where submissions get sent. Can be your personal email or a shared inbox.
POSSIBILIA_TO_EMAIL=ollipayne182@gmail.com

# Password gate for the unlisted /ours/collect storefront (see
# middleware.ts + lib/storefront-auth.ts). Set this on Railway to open
# the gate; UNSET it after the event to take the page down — no
# redeploy needed, every request fails closed. Set it locally in
# .env.local too if you want to test the gated flow on your machine.
STOREFRONT_PASSWORD=
